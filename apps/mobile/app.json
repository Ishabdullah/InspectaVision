{
  "expo": {
    "name": "Inspectavision",
    "slug": "inspectavision",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.inspectavision.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.inspectavision.app"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-media-library"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
