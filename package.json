{
  "name": "inspectavision",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "android:dev": "cd apps/android && ./gradlew assembleDebug",
    "android:build": "cd apps/android && ./gradlew assembleRelease",
    "android:clean": "cd apps/android && ./gradlew clean",
    "android:install": "cd apps/android && ./gradlew installDebug"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.0.0"
  }
}
